{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Abdomen MRI Segmentation Result",
  "type": "object",
  "required": ["summary", "measurements", "qa_flags", "qa_details", "model_version", "model_checksum", "artifacts"],
  "properties": {
    "summary": {
      "type": "object",
      "required": ["hepatomegaly_suspected", "splenomegaly_suspected", "organ_count_segmented"],
      "properties": {
        "hepatomegaly_suspected": { "type": "boolean" },
        "splenomegaly_suspected": { "type": "boolean" },
        "organ_count_segmented": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Number of organs with non-zero segmentation volume"
        },
        "segmentation_labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "sequences_used": {
          "type": "array",
          "items": { "type": "string" }
        },
        "processing_notes": { "type": "string" }
      }
    },
    "measurements": {
      "type": "object",
      "required": [
        "volumes_ml",
        "total_parenchymal_volume_ml"
      ],
      "properties": {
        "volumes_ml": {
          "type": "object",
          "description": "Per-organ volumes in mL",
          "properties": {
            "liver": { "type": "number", "minimum": 0 },
            "spleen": { "type": "number", "minimum": 0 },
            "right_kidney": { "type": "number", "minimum": 0 },
            "left_kidney": { "type": "number", "minimum": 0 },
            "pancreas": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": { "type": "number" }
        },
        "total_parenchymal_volume_ml": { "type": "number", "minimum": 0 },
        "voxel_spacing_mm": {
          "type": "array",
          "items": { "type": "number" }
        },
        "image_dimensions": {
          "type": "array",
          "items": { "type": "integer" }
        }
      }
    },
    "qa_flags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "qa_details": {
      "type": "object",
      "additionalProperties": true
    },
    "model_version": { "type": "string" },
    "model_checksum": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "artifact_type", "local_path", "content_type"],
        "properties": {
          "name": { "type": "string" },
          "artifact_type": { "type": "string" },
          "local_path": { "type": "string" },
          "content_type": { "type": "string" }
        }
      }
    }
  }
}
