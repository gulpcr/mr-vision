# ============================================
# MRI AI Platform - Environment Configuration
# ============================================
# Copy this file to .env and replace all placeholder values.

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mri_platform
POSTGRES_USER=mri_admin
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=mri_minio_admin
MINIO_SECRET_KEY=REPLACE_WITH_SECURE_PASSWORD
MINIO_BUCKET=mri-artifacts
MINIO_SECURE=false

# --- Orthanc ---
ORTHANC_HOST=orthanc
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
API_KEY=REPLACE_WITH_SECURE_API_KEY

# --- CORS ---
# Comma-separated list of allowed origins, or * for all (dev only)
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=2

# --- GPU ---
CUDA_VISIBLE_DEVICES=0
ENABLE_GPU=true

# --- Site ---
SITE_ID=default

# --- Routing / auto-classification ---
# When true, a use-case rule that declares region conditions (body parts / study
# or series description patterns) only matches a study that positively matches at
# least one of them — modality is necessary but not sufficient. Prevents an MR
# study with sparse DICOM tags from routing to every MR use case. Set false for
# legacy OR-matching (modality OR any region condition).
ROUTING_REQUIRE_REGION_MATCH=true

# --- Viewer: hide non-diagnostic series ---
# When true, the OHIF series list is filtered (via the QIDO /series response) to
# drop localizer / shim / calibration / field-map / scout series that render as
# noise. Pixels/WADO are untouched. Set false to show every series.
VIEWER_HIDE_NONDIAGNOSTIC_SERIES=true

# --- LLM Report Generation (Phase 1) ---
# Set LLM_ENABLED=true and supply a Gemini API key to add AI narrative impressions to PDF reports.
# Get a key at https://aistudio.google.com/
LLM_ENABLED=false
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# --- VLM Image Quality Assessment (Phase 2) ---
# Set VLM_QA_ENABLED=true to run Gemini Vision QA on rendered MRI slices before inference.
# Requires GEMINI_API_KEY above. VLM_QA_MAX_SERIES caps API calls per study.
VLM_QA_ENABLED=false
VLM_QA_MAX_SERIES=3

# --- LLM Clinical Decision Support (Phase 3) ---
# Set CDS_ENABLED=true to generate risk-stratified clinical context after each inference.
# Output is stored in Result.summary["clinical_context"] and rendered in PDF reports.
# Requires GEMINI_API_KEY above. All CDS output carries a mandatory radiologist review disclaimer.
CDS_ENABLED=false

# --- LLM Longitudinal Trend Analysis (Phase 4) ---
# Set LONGITUDINAL_ENABLED=true to compare the current study against prior results for the same
# patient. Generates trend assessment (progression/regression/stable), response categories
# (RANO 2.0, PERCIST 1.0, etc.), and key metric changes across timepoints.
# Stored in Result.summary["longitudinal_analysis"] and rendered as a PDF section.
# Requires GEMINI_API_KEY above and at least one prior result for the patient.
LONGITUDINAL_ENABLED=false
LONGITUDINAL_MAX_PRIOR_STUDIES=5

# --- DICOM SR / Seg Export (Phase 7) ---
# Set DICOM_SR_ENABLED=true to export AI measurements as a DICOM Structured Report to Orthanc
# after every completed pipeline run. The SR encodes all measurements, QA flags, and LLM
# clinical context as TID 2000 Basic Text SR content items.
# Set DICOM_SEG_ENABLED=true to additionally export the segmentation NIfTI as a DICOM
# Segmentation Image object. Requires highdicom (already in main dependencies).
# Both objects appear in Orthanc/OHIF under the same Study as a new SR/SEG series.
DICOM_SR_ENABLED=false
DICOM_SEG_ENABLED=false
